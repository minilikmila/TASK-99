# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://civicforum:civicforum@localhost:5432/civicforum

# Auth
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# Rate Limiting (in-memory)
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600

# Auth lockout
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# Logging
LOG_LEVEL=info

# Internal API key — required for notification dispatch/retry endpoints.
# Set to any strong random string (openssl rand -hex 32).
# Leave blank to disable internal endpoints (they will return 503).
INTERNAL_API_KEY=
