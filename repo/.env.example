# CivicForum Operations Platform — environment variable reference.
#
# docker compose up works out of the box with development defaults.
# No .env file is required for local development.
#
# In production, override the required secrets via your deployment system
# (K8s secrets, ECS task definitions, etc.). The app refuses to start in
# production if JWT_SECRET or INTERNAL_API_KEY are weak or missing.
#
# Generate secrets with: openssl rand -hex 32

# Application
NODE_ENV=development
PORT=3000

# Database (MySQL)
DATABASE_URL=mysql://civicforum:civicforum@localhost:3306/civicforum
MYSQL_ROOT_PASSWORD=civicforum
MYSQL_USER=civicforum
MYSQL_PASSWORD=civicforum
MYSQL_DATABASE=civicforum

# Auth — JWT_SECRET must be >= 32 chars and must NOT start with "local-dev-", "dev-secret-", etc.
# The app refuses to start in production if this is weak or missing.
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# Rate Limiting (in-memory)
RATE_LIMIT_WRITE_PER_MIN=120
RATE_LIMIT_READ_PER_MIN=600

# Auth lockout
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# Logging
LOG_LEVEL=info

# Internal API key — required for notification dispatch/retry endpoints.
# Must be >= 32 chars and non-default. The app refuses to start in production without it.
INTERNAL_API_KEY=change-me-to-a-strong-random-key-at-least-32-chars

# Admin bootstrap — set these to provision the first admin in production.
# In development/test, defaults ("admin" / "admin-password-secure") are used.
# ADMIN_USERNAME=myadmin
# ADMIN_PASSWORD=my-strong-password-at-least-12-chars

# Alert thresholds (sliding window)
# ALERT_ERROR_THRESHOLD=50
# ALERT_AUTH_FAILURE_THRESHOLD=30
# ALERT_RATE_LIMITED_THRESHOLD=100
# ALERT_WINDOW_MINUTES=5

# Backup
# BACKUP_VOLUME_PATH=/backups
# BACKUP_RETENTION_DAYS=14
