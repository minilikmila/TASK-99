{
  "name": "civicforum-ops-platform",
  "version": "1.0.0",
  "description": "CivicForum Operations Platform — offline-first multi-tenant civic forum backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node scripts/seed.ts",
    "test:unit": "jest --testPathPattern=unit_tests --verbose --forceExit",
    "test:api": "jest --testPathPattern=API_tests --verbose --forceExit --runInBand",
    "test": "jest --verbose --forceExit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.9",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/unit_tests", "<rootDir>/API_tests"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "testTimeout": 15000,
    "verbose": true,
    "moduleNameMapper": {
      "^@prisma/client$": "<rootDir>/__mocks__/@prisma/client.ts"
    },
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "diagnostics": false }]
    }
  }
}
